# Frontend (Vite)
# API-Endpunkt für den Adapter-Service
VITE_ADAPTER_ENDPOINT=/api/games

# Lokaler LLM-Endpunkt (Qwen/Ollama)
VITE_LLM_ENDPOINT=/ollama

# Timeouts in Millisekunden
VITE_ADAPTER_TIMEOUT_MS=15000
VITE_LLM_TIMEOUT_MS=120000
VITE_LLM_TIMEOUT_OLLAMA_MS=180000
VITE_LLM_TIMEOUT_OPENAI_MS=120000

# Adapter-Service
ADAPTER_HOST=0.0.0.0
ADAPTER_PORT=8787
CORS_ORIGIN=*
ADAPTER_TOKEN=
ADAPTER_MAX_BODY_BYTES=1048576

# Datenquellen
ADAPTER_DATA_FILE=./adapter-service/data/games.sample.json
ADAPTER_STORE_FILE=./adapter-service/data/games.store.json
ADAPTER_IMPORT_DIR=./adapter-service/imports
ADAPTER_ALIASES_FILE=./adapter-service/data/team-aliases.json
ADAPTER_REMOTE_URL=
ADAPTER_REMOTE_TOKEN=
ADAPTER_REFRESH_INTERVAL_SEC=0

# Automatische Wochen-Aktualisierung
ADAPTER_AUTO_REFRESH_WEEK=true
ADAPTER_WEEK_REFRESH_TTL_SEC=300
ADAPTER_WEEK_SOURCE_URL_TEMPLATE=
ADAPTER_WEEK_SOURCE_TOKEN=
ADAPTER_EXPORT_COMMAND=
ADAPTER_WEEK_COMMAND_TIMEOUT_MS=30000

# Fussball.de Exporter
FUSSBALLDE_BASE_URL=https://www.fussball.de
FUSSBALLDE_MANDANT=22
FUSSBALLDE_REQUEST_TIMEOUT_MS=15000
FUSSBALLDE_PAGE_CONCURRENCY=4
FUSSBALLDE_MATCH_CONCURRENCY=6
FUSSBALLDE_MAX_COMPETITIONS=80
FUSSBALLDE_MAX_MATCHES=600
FUSSBALLDE_SAISON=
FUSSBALLDE_COMPETITION_TYPE=

# Debug
SCOUTPLAN_DEBUG_EXPORTER=false
